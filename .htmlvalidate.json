{
  "extends": ["html-validate:recommended"],
  "rules": {
    "no-trailing-whitespace": "off",
    "element-required-attributes": "warn",
    "doctype-style": "off",
    "attr-quotes": "off",
    "void-style": "off",
    "aria-label": "off",
    "aria-labelledby": "off",
    "unique-landmark": "off",
    "no-inline-style": [
      "warn",
      {
        "allowedProperties": ["background-image"]
      }
    ],
    "tel-non-breaking": "off",
    "wcag/h63": "warn"
  }
}
