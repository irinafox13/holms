<div class="slider-navigation">
  <button
    type="button"
    class="button button--action button--action--circle slider-navigation__button slider-navigation__button--prev js-slider-prev"
    aria-label="Предыдущий слайд"
  >
    <svg width="24" height="24">
      <use href="#slider-arrow" />
    </svg>
  </button>
  <button
    type="button"
    class="button button--action button--action--circle slider-navigation__button slider-navigation__button--next js-slider-next"
    aria-label="Следующий слайд"
  >
    <svg width="24" height="24">
      <use href="#slider-arrow" />
    </svg>
  </button>
</div>
