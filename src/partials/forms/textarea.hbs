<div class="form-field form-field--textarea js-form-field {{content.disabled}}">
    <textarea
        name="{{content.name}}"
        class="form-field__input form-field__textarea js-form-field-input js-autoheight-textarea"
        autocomplete="off"
        maxlength="1000"
        {{#if content.required}}required{{/if}}
        {{content.disabled}}
        value="{{content.value}}"
    ></textarea>
    <label class="form-field__label">{{content.title}}</label>
</div>
