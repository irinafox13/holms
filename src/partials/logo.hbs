<div class="logo {{ dopClass }}">
  <span class="visually-hidden">Логотип ЖК "Холмс"</span>
  {{#ifCond page '==' 'main'}}
  <a href="#top" aria-label="Вернуться наверх">
    <svg width="248" height="40">
      <use href="#logo" />
