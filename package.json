    "fslightbox": "^3.7.5",
    "gsap": "^3.14.2",
    "normalize.css": "^8.0.1",
    "nouislider": "^15.8.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "swiper": "^12.1.2",
    "tippy.js": "^6.3.7",
    "tom-select": "^2.5.2",
    "urijs": "^1.19.11",
    "vite-plugin-commonjs": "^0.10.4"
  },
  "devDependencies": {
    "@babel/plugin-transform-class-properties": "^7.28.6",
