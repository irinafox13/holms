    "@types/urijs": "^1.19.26",
    "babel-plugin-add-module-exports": "^1.0.4",
    "cssnano": "^7.1.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
