{
  "include": [
    "src/scripts/std/**/*.ts",
    "src/**/*.js",
    "vite.config.js"
  ],
  "compilerOptions": {
    "allowJs": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "noEmit": true,
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "baseUrl": ".",
    "paths": {
      "@main/*": ["src/scripts/main/*"],
      "@std/*": ["src/scripts/std/*"],
      "@partials/*": ["src/partials/*"],
      "@components/*": ["src/scripts/main/components/*"],
      "@helpers/*": ["src/scripts/main/helpers/*"],
      "@utils/*": ["src/scripts/main/helpers/*"],
      "@styles/*": ["src/styles/*"],
      "@images/*": ["src/assets/images/*"]
    },
    "typeRoots": ["./node_modules/@types"],
    "resolveJsonModule": true
  }
}
